{
  "name": "blueprint-mcp",
  "version": "0.1.3",
  "description": "MCP server for architecture-aware Blueprint memory using Tree-sitter",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "blueprint-mcp": "dist/index.js",
    "blueprint-mcp-server": "dist/index.js",
    "blueprint": "dist/cli/index.js"
  },
  "files": [
    "dist",
    "docs",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/engincankaya/blueprint.git"
  },
  "bugs": {
    "url": "https://github.com/engincankaya/blueprint/issues"
  },
  "homepage": "https://github.com/engincankaya/blueprint#readme",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "blueprint",
    "llm",
    "coding-agent",
    "tree-sitter"
  ],
  "license": "MIT",
  "scripts": {
    "build": "npm run clean && tsc && npm run build:frontend && node scripts/copy-grammars.js && node scripts/add-shebang.js",
    "build:frontend": "tsc -p frontend/tsconfig.json --noEmit && vite build --config frontend/vite.config.ts",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "fast-glob": "^3.3.3",
    "uuid": "^11.1.0",
    "web-tree-sitter": "^0.24.4",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.1.1",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/uuid": "^10.0.0",
    "autoprefixer": "^10.4.21",
    "clsx": "^2.1.1",
    "framer-motion": "^11.15.0",
    "lucide-react": "^0.469.0",
    "postcss": "^8.5.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^2.6.0",
    "tailwindcss": "^3.4.18",
    "tree-sitter-cli": "^0.24.4",
    "tree-sitter-go": "^0.23.4",
    "tree-sitter-java": "^0.23.5",
    "tree-sitter-python": "^0.23.6",
    "tree-sitter-rust": "^0.23.2",
    "tree-sitter-typescript": "^0.23.2",
    "tree-sitter-wasms": "^0.1.13",
    "typescript": "^5.7.0",
    "vite": "^7.2.7",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
